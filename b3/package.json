{
  "name": "b3",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "overrides": {
    "axios": "1.16.0",
    "vite": "^7.3.1",
    "vitest": {
      "vite": "^7.3.1"
    },
    "@strapi/admin": {
      "axios": "1.16.0",
      "date-fns": "2.30.0"
    },
    "@strapi/plugin-cloud": {
      "@strapi/admin": {
        "axios": "1.16.0"
      }
    }
  },
  "workspaces": [
    "packages/*",
    "app",
    "cms",
    "apps/eco",
    "onboarding/frontend"
  ],
  "scripts": {
    "build": "echo \"Use npm run build --workspace app\"",
    "dev": "npm --prefix app run dev",
    "dev:platform": "bash scripts/dev-platform.sh",
    "dev:strapi": "npm --prefix cms run develop",
    "dev:strapi:setup": "npm --prefix cms run bootstrap && npm --prefix cms run ensure:local",
    "dev:full": "bash scripts/dev-full.sh",
    "dev:healthcheck": "node scripts/dev-healthcheck.mjs",
    "dev:onboarding": "npm --prefix onboarding/frontend run start",
    "db:start": "bash scripts/start-local-db.sh",
    "db:migrate": "cd app && npx prisma migrate deploy",
    "contracts:sdk": "node scripts/sync-contracts-sdk.mjs",
    "pulse:ingest": "npm --prefix app run pulse:ingest",
    "pulse:seed": "npm --prefix app run pulse:seed",
    "pulse:attest": "npm --prefix app run pulse:attest",
    "deploy:sepolia": "bash scripts/deploy-platform-sepolia.sh",
    "deploy:pulse-mainnet": "PULSE_ATTEST_CHAIN_ID=8453 bash scripts/deploy-pulse-anchor.sh",
    "sync:deploy-env": "bash scripts/sync-deploy-env.sh",
    "deploy:full-stack": "bash scripts/deploy-full-stack.sh",
    "smoke:production": "bash scripts/production-smoke.sh",
    "verify:app": "npm --prefix app run verify",
    "verify:frontend": "npm run verify:app",
    "verify:contracts": "cd contracts && forge test && npm run compile",
    "audit:app": "npm --prefix app run audit",
    "test:smoke": "npm --prefix app run test:smoke",
    "test:all": "npm run verify:app && npm run verify:contracts",
    "temporal:dev": "npm --prefix packages/temporal-worker run temporal:dev",
    "temporal:worker": "npm --prefix packages/temporal-worker run worker",
    "temporal:start-workflow": "npm --prefix packages/temporal-worker run start-workflow",
    "bcd-orchestration:build": "npm --prefix packages/bcd-orchestration run build"
  },
  "devDependencies": {
    "@strapi/plugin-cloud": "^5.44.0",
    "@strapi/plugin-users-permissions": "^5.44.0",
    "@strapi/strapi": "^5.44.0",
    "@types/node": "^22.15.3",
    "date-fns": "^2.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "styled-components": "^6.4.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^7.3.1"
  }
}
