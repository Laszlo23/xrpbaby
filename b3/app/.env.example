# Copy to .env — never commit .env
# See ../../SECURITY.md

# App / chain
# VITE_* are exposed to the browser — do not put server-only secrets here
VITE_PLATFORM_ORIGIN=http://localhost:5173
VITE_BASE_RPC_URL=https://mainnet.base.org
VITE_EVM_CHAIN_ID=8453

# Culture Layer identity (Base) — mint dashboard on /pass (~$1.11 USD in ETH, on-chain mintPrice)
VITE_IDENTITY_CHAIN_ID=8453
VITE_IDENTITY_CONTRACT_ADDRESS=0x3634dD45BDdbEf2Aa1f4BEf50A97e4b844004863

# World App MiniKit — optional until you ship inside World App (see b3/docs/WORLD_MINI_APP.md)
# VITE_WORLD_MINI_APP_ID=
# VITE_WORLD_CHAIN_RPC_URL=
# Set to 0 to hide World Chain from the wallet chain list
# VITE_ENABLE_WORLD_CHAIN=1

# Contracts (optional overrides; SDK may use deployments/8453.json)
 VITE_AGENT_SHARE_CAMPAIGN_ADDRESS=0x130e320a386b1ff0228492ddd65c380131ba86e9
 VITE_BCD_TOKEN_ADDRESS=0xda64dceb00b88ee1b8f6168beb58f5a2a7226b72
# VITE_BCD_SALE_ADDRESS=
# VITE_BCD_SALE_ROUND_ID=1
# VITE_BCD_SALE_ELIGIBILITY_BASE=
# BCD chain — defaults to B3 mainnet (8333) if unset. Production Base mainnet: 8453. Staging Base Sepolia: 84532.
VITE_BCD_CHAIN_ID=8453
# Staging example:
# VITE_BCD_CHAIN_ID=84532
# VITE_EVM_NETWORK=base-sepolia
# VITE_BCD_TOKEN_ADDRESS=0x...
# VITE_BCD_GENESIS_CLAIM_ADDRESS=0x...
# Genesis merkle proofs — HTTPS origin (no trailing slash); browser fetches `${base}/${walletLowercase}.json`
# with `{ "allocation": "<wei>", "proof": ["0x...", ...] }`. Required for /mission claim UX unless users paste JSON.
# VITE_BCD_GENESIS_ELIGIBILITY_BASE=https://your-cdn.example.com/bcd-genesis
# VITE_THIRDWEB_CLIENT_ID=

# Server-only (TanStack Start server) — keep out of VITE_*
DATABASE_URL=
# PRIVATE_KEY=  # only if required for server-side signing; prefer KMS / agent-runtime on VPS
# THIRDWEB_SECRET_KEY=

# Optional integrations
# STRAPI_URL=
# STRAPI_API_TOKEN=   # server: Strapi read token for /docs and protected CMS reads
# NEYNAR_API_KEY=

# Product analytics (PostHog)
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Admin funnel widget (server)
# POSTHOG_PERSONAL_API_KEY=
# POSTHOG_PROJECT_ID=
# POSTHOG_HOST=https://eu.i.posthog.com

# Marketplace seller disclosure (mirrors on-chain Marketplace V3 fee when set)
# VITE_MARKETPLACE_PLATFORM_FEE_BPS=250
# VITE_MARKETPLACE_FEE_RECIPIENT=0x...

# Premium x402 (server) — agent-monetizable JSON feed GET /api/x402/premium
# See b3/docs/BCD_AGENT_MONETIZATION.md
#
# THIRDWEB_SECRET_KEY — required; createThirdwebClient for facilitator (never expose to browser)
# X402_SERVER_WALLET_ADDRESS — 0x + 40 hex; facilitator signer (thirdweb x402 wallet)
# X402_PAY_TO — optional 0x + 40 hex; settlement recipient override (treasury Safe)
# X402_PRICE — e.g. $0.25 (handler defaults to $0.01 if unset)
# X402_NETWORK — base | base-sepolia | arbitrum-sepolia (default: base mainnet)
# X402_PUBLIC_ORIGIN — canonical https origin behind reverse proxy so resourceUrl matches signed payment
# PUBLIC_APP_ORIGIN — same canonical URL when possible; x402 CORS OPTIONS + manifests (see premiumCorsHeadersFor)
# Optional: X402_CORS_ORIGINS=comma-separated origins; X402_ALLOW_ANY_ORIGIN=1 (avoid in production)
#
# THIRDWEB_SECRET_KEY=
# X402_SERVER_WALLET_ADDRESS=0x
# X402_PAY_TO=0x
# X402_PRICE=$0.25
# X402_NETWORK=base
# X402_PUBLIC_ORIGIN=https://app.buildingculture.capital
# PUBLIC_APP_ORIGIN=https://app.buildingcultureid.space
# VITE_APP_ORIGIN=https://app.buildingcultureid.space
# VITE_PLATFORM_ORIGIN=https://app.buildingcultureid.space
# X402_CORS_ORIGINS=
# X402_ALLOW_ANY_ORIGIN=0

# Observability (client)
# VITE_SENTRY_DSN=

# Sitemap: comma-separated community profile slugs to include
# PROFILE_SITEMAP_SLUGS=alice,bob

# Elias orb — floating ecosystem guide (needs Supabase migration 002 for thread_kind)
# VITE_ELIAS_ORB_ENABLED=1

# Elias Concierge (Supabase + optional Resend + staff approvals)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Elias Concierge <updates@resend.dev>
# ELIAS_ADMIN_SECRET=
# ELIAS_INBOUND_SECRET=

# Elias LLM — OpenAI (default if both keys exist) or Anthropic Claude
# OPENAI_API_KEY=   # also used by Pulse Coach
# ELIAS_LLM_PROVIDER=anthropic   # force Claude when OPENAI_API_KEY is also set
# AI_MODEL=gpt-4o-mini
# ELIAS_LLM_MAX_RETRIES=8   # retries for both providers; falls back to OPENAI_MAX_RETRIES
# OPENAI_MAX_RETRIES=8
# OPENAI_TIMEOUT_MS=120000   # OpenAI HTTP client only
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# 0G APAC Hackathon proof page (/0g/agentid)
# VITE_OG_AGENT_ID_CONTRACT_ADDRESS=0x...
# VITE_OG_AGENT_ID_DEPLOY_TX=0x...
# VITE_OG_AGENT_ID_MINT_TX=0x...

# X (Twitter) quests UI — status URL for reply / repost / quote intents (points ledger)
# Must match the numeric id in X_OFFICIAL_QUEST_TARGET_TWEET_ID when using API verification.
# VITE_X_TARGET_POST_URL=https://x.com/yourhandle/status/1234567890

# X API (server-only; OAuth 1.0a user context for read + post). Do not use VITE_*.
# When all four are set, X quest proofs are verified via API; otherwise URL shape only.
# X_CONSUMER_KEY=
# X_CONSUMER_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=
# Numeric id of the official post users must reply to, repost, or quote (align with VITE_X_TARGET_POST_URL).
# X_OFFICIAL_QUEST_TARGET_TWEET_ID=
# Optional app-only Bearer (not required for current features).
# X_BEARER_TOKEN=

# POST /api/marketing/x-post — header x-x-marketing-admin-secret must match.
# X_MARKETING_ADMIN_SECRET=
# Optional: override public origin for scripts/x-marketing-post.mjs when posting from SSH (else PUBLIC_APP_ORIGIN / VITE_APP_ORIGIN).
# X_MARKETING_PUBLIC_ORIGIN=https://app.example.com

# --- Culture Pulse (transparency hub at /signal) ---
FACEBOOK_STREAM=false
TIKTOK_STREAM=false
INSTAGRAM_STREAM=false
