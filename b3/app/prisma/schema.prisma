generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Unified platform member (wallet-first; optional email / Farcaster).
model Member {
  id            String   @id @default(cuid())
  walletAddress String?  @unique
  farcasterFid  Int?     @unique
  email         String?  @unique
  displayName   String?
  intent        String?  // explore | build | gather
  supporterTier String   @default("community") // community | founding | elder
  forestStage   String   @default("seedling") // seedling | sapling | tree | grove
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  wallet        Wallet?         @relation(fields: [walletId], references: [id])
  walletId      String?         @unique
  activities      ActivityEvent[]
  rewardGrants    RewardGrant[]
  socialComments  SocialComment[]
}

model Wallet {
  id        String   @id @default(cuid())
  address   String   @unique
  createdAt DateTime @default(now())

  member         Member?
  ledgers        PointLedger[]
  airdropAllocs  AirdropAllocation[]
}

model PointLedger {
  id        String   @id @default(cuid())
  walletId  String
  wallet    Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  delta     Int
  reason    String
  taskSlug  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([walletId])
}

model TaskDefinition {
  id     String  @id @default(cuid())
  slug   String  @unique
  title  String
  points Int
  active Boolean @default(true)
}

model AirdropCampaign {
  id         String    @id @default(cuid())
  slug       String    @unique
  status     String    @default("draft")
  snapshotAt DateTime?
  merkleRoot String?

  allocations AirdropAllocation[]
}

model AirdropAllocation {
  id             String          @id @default(cuid())
  campaignId     String
  campaign       AirdropCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  walletId       String
  wallet         Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amountWei      String?
  pointsSnapshot Int?

  @@index([campaignId])
  @@index([walletId])
}

/// Append-only activity log (quests, analytics, social, modules).
model ActivityEvent {
  id           String   @id @default(cuid())
  memberId     String?
  member       Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  type         String
  sourceModule String   @default("app")
  payload      Json?
  createdAt    DateTime @default(now())

  @@index([memberId, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
}

/// Keys, badges, mystery boxes, campaign credits.
model RewardGrant {
  id         String   @id @default(cuid())
  memberId   String
  member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  kind       String
  amount     Int      @default(1)
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([memberId])
}

/// Ingested social post (Farcaster, X, Meta, TikTok, or native curator).
model SocialFeedItem {
  id           String   @id @default(cuid())
  platform     String
  externalId   String?
  authorHandle String?
  authorName   String?
  content      String
  mediaUrls    Json?
  permalink    String?
  metrics      Json?
  publishedAt  DateTime
  ingestedAt   DateTime @default(now())
  featured     Boolean  @default(false)
  comments     SocialComment[]

  @@unique([platform, externalId])
  @@index([publishedAt(sort: Desc)])
  @@index([platform, publishedAt(sort: Desc)])
}

/// Platform-native comment on a feed item (SIWE-gated).
model SocialComment {
  id         String   @id @default(cuid())
  feedItemId String
  feedItem   SocialFeedItem @relation(fields: [feedItemId], references: [id], onDelete: Cascade)
  memberId   String
  member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  body       String
  createdAt  DateTime @default(now())
  hidden     Boolean  @default(false)

  @@index([feedItemId, createdAt(sort: Desc)])
}

/// Point-in-time growth metrics for transparency dashboard.
model GrowthSnapshot {
  id             String   @id @default(cuid())
  capturedAt     DateTime @default(now())
  memberCount    Int
  waitlistCount  Int
  culturePoints  Int
  activity24h    Int
  farcasterItems Int
  xItems         Int
  facebookItems  Int      @default(0)
  tiktokItems    Int      @default(0)
  instagramItems Int      @default(0)
  nativeComments Int
  digest         String

  @@index([capturedAt(sort: Desc)])
}

/// Record of daily on-chain attestation tx.
model PulseAttestation {
  id          String   @id @default(cuid())
  dayId       String   @unique
  digest      String
  metadataUri String
  chainId     Int
  txHash      String
  blockNumber Int?
  createdAt   DateTime @default(now())
}

/// Landing waitlist until member converts.
model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String?
  source    String?
  createdAt DateTime @default(now())
}

/// Append-only log for @bc/agent-runtime ticks (ops + on-chain intents).
model AgentActionLog {
  id        String   @id
  agentId   String
  createdAt DateTime @default(now())
  action    String
  params    Json?
  dryRun    Boolean  @default(false)
  txHash    String?
  status    String
  errorMsg  String?
  costUsd   String?

  @@index([agentId, createdAt(sort: Desc)])
  @@index([createdAt])
}

/// Ingested AgentShareCampaign `Minted` logs (server-side indexer).
model ChainMintEvent {
  id              String   @id @default(cuid())
  chainId         Int
  contractAddress String
  blockNumber     BigInt
  txHash          String
  logIndex        Int
  toAddress       String
  tokenId         String
  agentTypeId     Int?
  referrer        String?
  createdAt       DateTime @default(now())

  @@unique([chainId, txHash, logIndex])
  @@index([contractAddress, blockNumber])
  @@index([toAddress])
}
