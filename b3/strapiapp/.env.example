# Copy to .env — never commit .env
# See ../SECURITY.md

HOST=0.0.0.0
PORT=1337
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
JWT_SECRET=

# Production: comma-separated allowed origins (required when NODE_ENV=production)
CORS_ORIGIN=http://localhost:3000

# SIWE wallet auth for community profiles
# SIWE_ALLOWED_DOMAINS=app.example.com,localhost:5173
# WALLET_AUTH_CHAIN_IDS=8453

# Server-to-server (e.g. frontend /docs loader)
# STRAPI_API_TOKEN=

DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
