# Public site URL (canonical links, OG tags, share URLs)
VITE_SITE_URL=https://buildingcultureid.space

# Farcaster mini app (mini.buildingcultureid.space)
VITE_MINI_APP_ORIGIN=https://mini.buildingcultureid.space
# FID of @buildingcultu3 for follow quest verification
VITE_FARCASTER_ACCOUNT_FID=
VITE_QUEST_HASHTAG=BuildingCulture
# Set true to test mini UI on localhost
VITE_FORCE_MINI_APP=false

# Base Sepolia (84532) or Base mainnet (8453)
VITE_CHAIN_ID=84532

# Deployed CultureLayerIdentity contract
VITE_IDENTITY_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Optional — defaults to public Base RPC for the selected chain
VITE_RPC_URL=https://sepolia.base.org

# WalletConnect Cloud project id (https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=

# Contract deploy (Foundry) — default mint price = 0.00333 ETH
MINT_PRICE_WEI=3330000000000000
PRIVATE_KEY=

# Server-only social APIs (never use VITE_ prefix)
NEYNAR_API_KEY=
# Neynar hosted Snapchain node (casts); same API key as above
NEYNAR_SNAPCHAIN_URL=https://snapchain-api.neynar.com/v1
ALCHEMY_API_KEY=
