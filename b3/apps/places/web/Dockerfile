# Production image for Next.js (standalone output). Build from repo: docker compose build
# NEXT_PUBLIC_* must be available at build time (inlined into the client bundle).
FROM node:20-bookworm-slim AS deps
WORKDIR /app
COPY web/package.json web/package-lock.json ./
RUN npm ci

FROM node:20-bookworm-slim AS builder
WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1
COPY --from=deps /app/node_modules ./node_modules
COPY web/ ./

# Site + WalletConnect
ARG NEXT_PUBLIC_SITE_URL=https://buildingculture.capital
ENV NEXT_PUBLIC_SITE_URL=${NEXT_PUBLIC_SITE_URL}
ARG NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID
ENV NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=${NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID}

# Legacy non-BASE_* envs (optional docker builds); production uses NEXT_PUBLIC_BASE_* (see web/README.md)
ARG NEXT_PUBLIC_OG_RPC
ENV NEXT_PUBLIC_OG_RPC=${NEXT_PUBLIC_OG_RPC}
ARG NEXT_PUBLIC_EXPLORER
ENV NEXT_PUBLIC_EXPLORER=${NEXT_PUBLIC_EXPLORER}
ARG NEXT_PUBLIC_REGISTRY
ENV NEXT_PUBLIC_REGISTRY=${NEXT_PUBLIC_REGISTRY}
ARG NEXT_PUBLIC_SHARE_FACTORY
ENV NEXT_PUBLIC_SHARE_FACTORY=${NEXT_PUBLIC_SHARE_FACTORY}
ARG NEXT_PUBLIC_COMPLIANCE_REGISTRY
ENV NEXT_PUBLIC_COMPLIANCE_REGISTRY=${NEXT_PUBLIC_COMPLIANCE_REGISTRY}
ARG NEXT_PUBLIC_WETH
ENV NEXT_PUBLIC_WETH=${NEXT_PUBLIC_WETH}
ARG NEXT_PUBLIC_ROUTER
ENV NEXT_PUBLIC_ROUTER=${NEXT_PUBLIC_ROUTER}
ARG NEXT_PUBLIC_LENDING_POOL
ENV NEXT_PUBLIC_LENDING_POOL=${NEXT_PUBLIC_LENDING_POOL}
ARG NEXT_PUBLIC_PREDICTION_MARKET
ENV NEXT_PUBLIC_PREDICTION_MARKET=${NEXT_PUBLIC_PREDICTION_MARKET}
ARG NEXT_PUBLIC_PROOF_NFT
ENV NEXT_PUBLIC_PROOF_NFT=${NEXT_PUBLIC_PROOF_NFT}
ARG NEXT_PUBLIC_STAKING
ENV NEXT_PUBLIC_STAKING=${NEXT_PUBLIC_STAKING}
ARG NEXT_PUBLIC_GUESTBOOK
ENV NEXT_PUBLIC_GUESTBOOK=${NEXT_PUBLIC_GUESTBOOK}

# Base mainnet (see web/src/lib/base-addresses.ts, web/src/wagmi.ts)
ARG NEXT_PUBLIC_BASE_RPC
ENV NEXT_PUBLIC_BASE_RPC=${NEXT_PUBLIC_BASE_RPC}
ARG NEXT_PUBLIC_BASE_EXPLORER
ENV NEXT_PUBLIC_BASE_EXPLORER=${NEXT_PUBLIC_BASE_EXPLORER}
ARG NEXT_PUBLIC_BASE_REGISTRY
ENV NEXT_PUBLIC_BASE_REGISTRY=${NEXT_PUBLIC_BASE_REGISTRY}
ARG NEXT_PUBLIC_BASE_SHARE_FACTORY
ENV NEXT_PUBLIC_BASE_SHARE_FACTORY=${NEXT_PUBLIC_BASE_SHARE_FACTORY}
ARG NEXT_PUBLIC_BASE_COMPLIANCE_REGISTRY
ENV NEXT_PUBLIC_BASE_COMPLIANCE_REGISTRY=${NEXT_PUBLIC_BASE_COMPLIANCE_REGISTRY}
ARG NEXT_PUBLIC_BASE_WETH
ENV NEXT_PUBLIC_BASE_WETH=${NEXT_PUBLIC_BASE_WETH}
ARG NEXT_PUBLIC_BASE_ROUTER
ENV NEXT_PUBLIC_BASE_ROUTER=${NEXT_PUBLIC_BASE_ROUTER}
ARG NEXT_PUBLIC_BASE_LENDING_POOL
ENV NEXT_PUBLIC_BASE_LENDING_POOL=${NEXT_PUBLIC_BASE_LENDING_POOL}
ARG NEXT_PUBLIC_BASE_PREDICTION_MARKET
ENV NEXT_PUBLIC_BASE_PREDICTION_MARKET=${NEXT_PUBLIC_BASE_PREDICTION_MARKET}
ARG NEXT_PUBLIC_BASE_PROOF_NFT
ENV NEXT_PUBLIC_BASE_PROOF_NFT=${NEXT_PUBLIC_BASE_PROOF_NFT}
ARG NEXT_PUBLIC_BASE_STAKING
ENV NEXT_PUBLIC_BASE_STAKING=${NEXT_PUBLIC_BASE_STAKING}
ARG NEXT_PUBLIC_BASE_GUESTBOOK
ENV NEXT_PUBLIC_BASE_GUESTBOOK=${NEXT_PUBLIC_BASE_GUESTBOOK}
ARG NEXT_PUBLIC_BASE_GOVERNANCE_SAFE
ENV NEXT_PUBLIC_BASE_GOVERNANCE_SAFE=${NEXT_PUBLIC_BASE_GOVERNANCE_SAFE}

# Veriff KYC (see web/src/components/kyc/VeriffKyc.tsx)
ARG NEXT_PUBLIC_VERIFF_HOST
ENV NEXT_PUBLIC_VERIFF_HOST=${NEXT_PUBLIC_VERIFF_HOST}
ARG NEXT_PUBLIC_VERIFF_API_KEY
ENV NEXT_PUBLIC_VERIFF_API_KEY=${NEXT_PUBLIC_VERIFF_API_KEY}

RUN npm run build

FROM node:20-bookworm-slim AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
RUN addgroup --system --gid 1001 nodejs && adduser --system --uid 1001 nextjs
COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
USER nextjs
EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
CMD ["node", "server.js"]
