# NEXT_PUBLIC_PRIMARY_SALES_JSON={"sales":[]}

# Optional
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Social profiles (default @buildingcultu3 URLs — override per platform if needed)
# NEXT_PUBLIC_SOCIAL_X=https://x.com/buildingcultu3
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://www.instagram.com/buildingcultu3/
# NEXT_PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/company/buildingcultu3

# Optional: concierge CTA mailto (see ContactConciergeCta)
# NEXT_PUBLIC_CONTACT_EMAIL=allocations@example.com
# Optional: whitelist requests from beta modal (falls back to NEXT_PUBLIC_CONTACT_EMAIL)
# NEXT_PUBLIC_WHITELIST_EMAIL=whitelist@example.com
# Optional: client event bus for analytics (see web/src/lib/analytics.ts) — align with /legal/privacy
# NEXT_PUBLIC_ANALYTICS_ENABLED=0

# KYC webhook + compliance relay (server-only)
