# Copy to `.env.local` in this directory. Next.js loads env from `web/` for `npm run dev`.
#
# Privy (wallet + auth UI) — required for the in-app Connect flow:
#   NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id
# (typo fallback also read: NEXT_PUBLIC_PRIVY_APPID — prefer APP_ID above)
# Optional: pin the dashboard app client (defaults are set in `src/app/providers.tsx` if unset):
#   NEXT_PUBLIC_PRIVY_CLIENT_ID=client-...
# Server-only — never expose as NEXT_PUBLIC_* (Privy REST / server SDK when you add backend calls):
#   PRIVY_APP_SECRET=
# JWKS (`https://auth.privy.io/api/v1/apps/<app_id>/jwks.json`) is only for verifying Privy JWTs on API routes — not used in PrivyProvider.
#
# Base mainnet (recommended):
#   python3 ../scripts/sync_web_env.py ../deployments/base-mainnet.json > .env.local
# Docker image: repo-root `.env` for `docker compose build` (see ../.env.docker.example)
#
# Internal QA only — optional second chain in Wagmi:
#   NEXT_PUBLIC_ENABLE_LEGACY_TESTNET=1
#   NEXT_PUBLIC_OG_RPC=https://evmrpc-testnet.0g.ai

# --- Base mainnet (chain id 8453) — sync from ../deployments/base-mainnet.json ---
NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org
NEXT_PUBLIC_BASE_EXPLORER=https://basescan.org
NEXT_PUBLIC_BASE_REGISTRY=0x5aca19274B17B97e38da9eA851d91F0CC59DafBf
