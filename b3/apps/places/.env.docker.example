# Copy to `.env` in the repo root (same directory as docker-compose.yml).
# `docker compose` loads `.env` for build-arg substitution. Do not commit real secrets.
#
# Generate from deployments (recommended):
#   { python3 scripts/sync_web_env.py deployments/testnet.json; python3 scripts/sync_web_env.py deployments/base-mainnet.json; echo "NEXT_PUBLIC_SITE_URL=https://buildingculture.capital"; } | grep -v '^$'  # then merge SITE_URL / WALLETCONNECT by hand
#
# Optional: NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_cloud_id
#
# Privy (web bundle): NEXT_PUBLIC_PRIVY_APP_ID / NEXT_PUBLIC_PRIVY_CLIENT_ID — see web/.env.local.example
# Server-only (never bake into client): PRIVY_APP_SECRET=
#
# Wallet sign-in (required for sessions, profile, community DB features):
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
#   SESSION_SECRET=   # openssl rand -hex 32 — min 16 chars
# Then once: psql "$DATABASE_URL" -f web/sql/schema.sql && psql "$DATABASE_URL" -f web/sql/community_schema.sql
# See web/sql/README.md

DATABASE_URL=
SESSION_SECRET=

NEXT_PUBLIC_SITE_URL=https://buildingculture.capital
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# 0G Galileo — replace with output from: python3 scripts/sync_web_env.py deployments/testnet.json
NEXT_PUBLIC_OG_RPC=https://evmrpc-testnet.0g.ai
