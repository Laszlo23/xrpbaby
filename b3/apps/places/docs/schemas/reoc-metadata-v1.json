{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ogchain.dev/schemas/reoc-metadata-v1.json",
  "title": "REOC property share metadata v1",
  "description": "Off-chain JSON for REOC v1 — see docs/standards/reoc-v1.md §4",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "reocVersion",
    "title",
    "propertyId",
    "registry",
    "chainId",
    "jurisdiction",
    "documents"
  ],
  "properties": {
    "reocVersion": {
      "type": "string",
      "const": "1.0.0",
      "description": "REOC metadata schema version; must match REOC v1."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable asset title (not necessarily legal description)."
    },
    "description": {
      "type": "string",
      "description": "Optional short narrative; avoid PII."
    },
    "propertyId": {
      "type": "string",
      "pattern": "^[0-9]+$",
      "description": "Decimal string of uint256 property id in the registry."
    },
    "registry": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$",
      "description": "Checksummed PropertyRegistry address."
    },
    "chainId": {
      "type": "integer",
      "minimum": 1,
      "description": "EIP-155 chain id."
    },
    "jurisdiction": {
      "type": "string",
      "minLength": 2,
      "description": "Region or legal venue code (e.g. US-CA, AT, EU-DE)."
    },
    "token": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "address": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{40}$",
          "description": "Property share token contract if known."
        },
        "symbol": { "type": "string" },
        "decimals": { "type": "integer", "minimum": 0, "maximum": 18 }
      }
    },
    "externalRefHint": {
      "type": "string",
      "description": "Optional non-normative hint; do not put legally sensitive plaintext here if document is public."
    },
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "DEED",
              "DISCLOSURE",
              "INSPECTION",
              "OFFERING",
              "APPRAISAL",
              "OTHER"
            ]
          },
          "uri": {
            "type": "string",
            "format": "uri",
            "description": "HTTPS, IPFS, or other resolvable URI."
          },
          "storageRoot": {
            "type": "string",
            "pattern": "^0x[a-fA-F0-9]{64}$",
            "description": "Merkle or content root committed on-chain."
          },
          "label": { "type": "string" }
        },
        "oneOf": [
          { "required": ["uri"] },
          { "required": ["storageRoot"] }
        ]
      }
    }
  }
}
