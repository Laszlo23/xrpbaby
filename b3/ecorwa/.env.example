# Copy to .env for local dev. All client-side vars use VITE_ prefix.

# Main experience market — ticket NFTs, BCD, gameplay (BUILDCHAIN / 0x app)
VITE_BUILDCHAIN_APP_URL=https://0x.buildingculture.capital

# Canonical URL of this eco/hub landing — match index.html <link rel="canonical"> when deploying
# VITE_ECO_HUB_LANDING_URL=https://eco.buildingculture.capital

# Footer / social (optional overrides)
# VITE_COMMUNITY_X_URL=https://x.com/buildingcultu3
# VITE_CONTACT_EMAIL=hello@buildingculture.capital

# Legal pages (imprint / privacy placeholders — set real values for production)
# VITE_LEGAL_ENTITY_NAME="Building Culture"
# VITE_LEGAL_ADDRESS="Street\nCity\nAustria"   # or comma-separated lines
# VITE_LEGAL_CONTACT_EMAIL=legal@buildingculture.capital
# VITE_LEGAL_UID_VAT=
# VITE_LEGAL_REGISTRY_COURT=
# VITE_LEGAL_REGISTRY_NUMBER=

# --- Optional Web3 stack (wagmi + thirdweb; off by default) -------------------
# VITE_ENABLE_WEB3=true
# VITE_THIRDWEB_CLIENT_ID=
# VITE_WALLETCONNECT_PROJECT_ID=
