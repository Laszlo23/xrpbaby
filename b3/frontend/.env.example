# Copy to .env — never commit .env
# See ../../SECURITY.md

# App / chain
# VITE_* are exposed to the browser — do not put server-only secrets here
VITE_BASE_RPC_URL=https://mainnet.base.org
VITE_EVM_CHAIN_ID=8453

# Contracts (optional overrides; SDK may use deployments/8453.json)
# VITE_AGENT_SHARE_CAMPAIGN_ADDRESS=
# VITE_BCD_TOKEN_ADDRESS=
# VITE_BCD_SALE_ADDRESS=
# VITE_BCD_SALE_ROUND_ID=1
# VITE_BCD_SALE_ELIGIBILITY_BASE=
# VITE_BCD_CHAIN_ID=8453
# VITE_THIRDWEB_CLIENT_ID=

# Server-only (TanStack Start server) — keep out of VITE_*
DATABASE_URL=
# PRIVATE_KEY=  # only if required for server-side signing; prefer KMS / agent-runtime on VPS
# THIRDWEB_SECRET_KEY=

# Optional integrations
# STRAPI_URL=
# STRAPI_API_TOKEN=   # server: Strapi read token for /docs and protected CMS reads
# NEYNAR_API_KEY=

# Product analytics (PostHog)
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Admin funnel widget (server)
# POSTHOG_PERSONAL_API_KEY=
# POSTHOG_PROJECT_ID=
# POSTHOG_HOST=https://eu.i.posthog.com

# Marketplace seller disclosure (mirrors on-chain Marketplace V3 fee when set)
# VITE_MARKETPLACE_PLATFORM_FEE_BPS=250
# VITE_MARKETPLACE_FEE_RECIPIENT=0x...

# Premium x402 (server)
# X402_PRICE=$0.25
# X402_PAY_TO=0x...

# Observability (client)
# VITE_SENTRY_DSN=

# Sitemap: comma-separated community profile slugs to include
# PROFILE_SITEMAP_SLUGS=alice,bob

# Elias orb — floating ecosystem guide (needs Supabase migration 002 for thread_kind)
# VITE_ELIAS_ORB_ENABLED=1

# Elias Concierge (Supabase + optional Resend + staff approvals)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Elias Concierge <updates@resend.dev>
# ELIAS_ADMIN_SECRET=
# ELIAS_INBOUND_SECRET=

# Agent-runtime x402 probe / absolute URLs
# PUBLIC_APP_ORIGIN=https://app.example.com

# Elias LLM — OpenAI (default if both keys exist) or Anthropic Claude
# OPENAI_API_KEY=   # also used by Pulse Coach
# ELIAS_LLM_PROVIDER=anthropic   # force Claude when OPENAI_API_KEY is also set
# AI_MODEL=gpt-4o-mini
# ELIAS_LLM_MAX_RETRIES=8   # retries for both providers; falls back to OPENAI_MAX_RETRIES
# OPENAI_MAX_RETRIES=8
# OPENAI_TIMEOUT_MS=120000   # OpenAI HTTP client only
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
