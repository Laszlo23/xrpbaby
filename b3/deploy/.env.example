# =============================================================================
# deploy/.env — used by docker compose AND copied into app/.env for builds
# =============================================================================
# Copy: cp deploy/.env.example deploy/.env
# Never commit deploy/.env.
#
# After an operator redeploys contracts, sync addresses from:
#   b3/contracts/deployments/8453.json
# then run from b3/:  npm run contracts:sdk
# and refresh the VITE_* lines below before rebuilding the web image.
# See also: deploy/POST_REDEPLOY_SYNC.md

# --- Postgres (compose + Prisma + Strapi) ---
POSTGRES_USER=buildingculture
POSTGRES_PASSWORD=change-me
POSTGRES_DB=buildingculture
POSTGRES_PORT=5432

# Single URL for app DB (Prisma). Strapi uses DATABASE_* below as well.
DATABASE_URL=postgresql://buildingculture:change-me@postgres:5432/buildingculture?schema=public

# --- Image tags (optional overrides) ---
# STRAPI_IMAGE=buildingculture-strapi:latest
# WEB_IMAGE=buildingculture-frontend:latest
# AGENT_RUNTIME_IMAGE=buildingculture-agent-runtime:latest
# INDEXER_IMAGE=buildingculture-indexer:latest

# --- Strapi (container env) ---
HOST=0.0.0.0
PORT=1337
NODE_ENV=production
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
JWT_SECRET=

DATABASE_CLIENT=postgres
# Redundant with DATABASE_URL but explicit for operators:
# DATABASE_HOST=postgres
# DATABASE_PORT=5432
# DATABASE_NAME=buildingculture
# DATABASE_USERNAME=buildingculture
# DATABASE_PASSWORD=change-me

# Comma-separated browser origins allowed to call Strapi (required in production)
CORS_ORIGIN=https://app.buildingcultureid.space,https://app.buildingculture.capital,https://0x.buildingculture.capital

# SIWE / wallet auth for community profiles
SIWE_ALLOWED_DOMAINS=app.buildingcultureid.space,app.buildingculture.capital,0x.buildingculture.capital
WALLET_AUTH_CHAIN_IDS=8453

# --- Frontend / SSR (web container + Vite build args) ---
# VITE_* are baked at `docker build` time — set before running app/scripts/docker-build.sh
VITE_BASE_RPC_URL=https://mainnet.base.org
VITE_EVM_CHAIN_ID=8453

# Current curated Base mainnet deployment (sync with contracts/deployments/8453.json)
VITE_BCD_TOKEN_ADDRESS=0xda64dceb00b88ee1b8f6168beb58f5a2a7226b72
VITE_BCD_GENESIS_CLAIM_ADDRESS=0x2bae6b04d0d1c8016cc863509395b68eb0021f58
# Culture Pulse anchor (DeployPulseAnchor @ 8453)
PULSE_ANCHOR_ADDRESS=0x503f8ad17c0fcdd84fbdbf7f51b41b39b02ebbae
PULSE_ATTEST_CHAIN_ID=8453
# BCDFixedPriceSale (after deploy; mirrors on-chain buy in GetBcdModal)
# VITE_BCD_SALE_ADDRESS=
# VITE_BCD_SALE_ROUND_ID=1
# Private round eligibility JSON: `${VITE_BCD_SALE_ELIGIBILITY_BASE}/${wallet}-${round}.json` with keys maxBcdWei (string), proof (0x32[])

# VITE_BCD_SALE_ELIGIBILITY_BASE=
VITE_RAFFLE_CAMPAIGN_ADDRESS=0xb1a88bf677400c23430b643a07229af832130ad8
VITE_AGENT_SHARE_CAMPAIGN_ADDRESS=0x130e320a386b1ff0228492ddd65c380131ba86e9

# Elias orb (floating ecosystem guide — requires Elias Supabase migrations including thread_kind)
# VITE_ELIAS_ORB_ENABLED=1

# VITE_THIRDWEB_CLIENT_ID=
# VITE_STRAPI_URL=https://api.buildingcultureid.space
STRAPI_URL=http://strapi:1337
STRAPI_API_TOKEN=

# Public origin for sitemaps / agent probes / pulse digest metadata
PUBLIC_APP_ORIGIN=https://app.buildingcultureid.space
VITE_PLATFORM_ORIGIN=https://app.buildingcultureid.space
VITE_APP_ORIGIN=https://app.buildingcultureid.space

# --- Indexer + agent-runtime ---
BASE_RPC_URL=https://mainnet.base.org
AGENT_BASE_RPC_URL=https://mainnet.base.org
AGENT_CHAIN_ID=8453
# INDEX_FROM_BLOCK=0

# Kill-switch and economics (see docs/TREASURY_POLICY.md)
AGENTS_PAUSED=1
ECON_LIVE=0

# AGS distributor (only when ECON_LIVE=1 and policy allows)
# AGENT_AGS_DISTRIBUTOR_PRIVATE_KEY=0x...

# Slack digest (optional)
# SLACK_WEBHOOK_URL=

# Intervals (seconds)
AGENT_TICK_INTERVAL_SEC=900
INDEXER_INTERVAL_SEC=300

# --- Premium x402 (web server) ---
# X402_PRICE=$0.25
# X402_PAY_TO=0x...
# Browser CORS: allow PUBLIC_APP_ORIGIN plus optional comma-separated origins
# X402_CORS_ORIGINS=https://staging.example.com
# Emergency only (not recommended for production):
# X402_ALLOW_ANY_ORIGIN=1

# --- Observability ---
# VITE_SENTRY_DSN=
# Sentry server DSN if used separately

# --- Optional SEO / embeds (Vite build) ---
# VITE_OG_IMAGE_URL=
# VITE_FARCASTER_EMBED_IMAGE=
# VITE_TWITTER_SITE=
# VITE_THEME_COLOR=
# VITE_BASE_APP_ID=
# VITE_GOOGLE_SITE_VERIFICATION=
# VITE_MS_VALIDATE=
# VITE_PROFILE_SITEMAP_SLUGS=
# VITE_DAILY_CHECKIN_ADDRESS=
# VITE_VAULT_ID=
# VITE_ECO_HUB_LANDING_URL=
